# open-interceptor configuration
#
# Copy this file to ~/.config/open-interceptor/config.yaml and adjust to your needs.
# Environment variables in api_key fields are expanded with shell syntax: ${VAR}

# Port the local proxy listens on. Claude Code will be pointed here via
# ANTHROPIC_BASE_URL=http://127.0.0.1:3300
port: 3300

# Log level: trace | debug | info | warn | error
log_level: info

# -----------------------------------------------------------------------------
# Providers
#
# Each provider has a unique key, a `type`, an upstream `url`, and an `api_key`.
#
# Types:
#   - anthropic_compatible: speaks the Anthropic Messages API natively (Anthropic, etc.)
#                           url is the origin (e.g. https://api.anthropic.com)
#   - openai_compatible:    speaks OpenAI Chat Completions; the proxy translates
#                           requests/responses to/from the Anthropic format.
#                           url must include the /v1 prefix (e.g. https://api.openai.com/v1)
#   - passthrough:          forwards the client's auth header untouched
#
# Optional `passthrough_auth: true` keeps the client's Authorization/x-api-key
# header instead of substituting with the provider's `api_key`.
#
# Optional `models:` declares which models this provider exposes for the
# /v1/models endpoint. Each model is an object with:
#   - id: model ID (required)
#   - context_window: total context in tokens (optional — surfaced in /v1/models
#     so Claude Code's /context shows the correct budget for the model)
#   - max_output_tokens: max output tokens (optional)
# If `models:` is omitted entirely, the proxy fetches the provider's own
# /v1/models and caches the result (only for anthropic_compatible providers).
# -----------------------------------------------------------------------------
providers:

  anthropic:
    type: anthropic_compatible
    url: https://api.anthropic.com
    api_key: ${ANTHROPIC_API_KEY}
    passthrough_auth: true
    models:
      - id: claude-opus-4-7
        context_window: 200000
      - id: claude-sonnet-4-6
        context_window: 200000
      - id: claude-haiku-4-5
        context_window: 200000

  # OpenCode Go — single subscription that routes to 12 open-source
  # coding models. The catch: only 2 of them (MiniMax M2.5/M2.7) expose
  # the Anthropic Messages format. The other 10 (GLM, Kimi, DeepSeek V4,
  # MiMo, Qwen) live behind /v1/chat/completions and need the Phase-3
  # translation layer. Hence two provider entries sharing the same
  # subscription key.
  #
  # Multiple API keys can be configured via api_keys: for round-robin
  # rotation and automatic failover on rate-limit (HTTP 429). Keys
  # marked as exhausted auto-reset after 5 minutes.
  # key_strategy: round_robin (default) | failover

  opencode-go-anthropic:
    type: anthropic_compatible
    url: https://opencode.ai/zen/go
    api_key: ${OPENCODE_GO_API_KEY}
    models:
      - id: minimax-m2.7
        context_window: 1000000
      - id: minimax-m2.5
        context_window: 1000000

  opencode-go-openai:
    type: openai_compatible
    url: https://opencode.ai/zen/go/v1
    api_key: ${OPENCODE_GO_API_KEY}
    # To use multiple subscriptions with automatic failover, replace
    # api_key above with:
    #   api_keys:
    #     - ${OPENCODE_GO_KEY_1}
    #     - ${OPENCODE_GO_KEY_2}
    #     - ${OPENCODE_GO_KEY_3}
    #   key_strategy: round_robin  # or failover
    models:
      - id: glm-5.1
        context_window: 128000
      - id: glm-5
        context_window: 128000
      - id: kimi-k2.6
        context_window: 128000
      - id: kimi-k2.5
        context_window: 128000
      - id: deepseek-v4-pro
        context_window: 128000
      - id: deepseek-v4-flash
        context_window: 128000
      - id: mimo-v2.5
        context_window: 32768
      - id: mimo-v2.5-pro
        context_window: 32768
      - id: qwen3.6-plus
        context_window: 128000
      - id: qwen3.5-plus
        context_window: 128000

  custom-openai:
    type: openai_compatible
    url: https://api.openai.com/v1
    api_key: ${OPENAI_API_KEY}
    models:
      - id: gpt-5
        context_window: 400000
      - id: gpt-4o
        context_window: 128000
      - id: o3-mini
        context_window: 200000

# -----------------------------------------------------------------------------
# Routes
#
# Evaluated top-to-bottom; first match wins. Pattern matching uses glob syntax
# (same as ripgrep's globset). `remap` optionally rewrites the model id before
# sending it upstream (useful when provider names differ from Claude Code's).
# -----------------------------------------------------------------------------
routes:

  # Claude models go to Anthropic
  - models: ["claude-*"]
    provider: anthropic

  # OpenCode Go — MiniMax through the native Anthropic endpoint.
  - models: ["minimax-*"]
    provider: opencode-go-anthropic

  # OpenCode Go — every other model goes through the OpenAI endpoint.
  - models:
      ["glm-*", "kimi-*", "deepseek-v4-*", "mimo-*", "qwen3*"]
    provider: opencode-go-openai

  # OpenAI families (with translation layer)
  - models: ["gpt-*", "o1-*", "o3-*", "o4-*"]
    provider: custom-openai
    remap:
      # Map Claude Code's name → upstream's actual id, if they differ
      # "gpt-5": "gpt-5-preview"

  # Default fallback — anything unknown goes to Anthropic
  - models: ["*"]
    provider: anthropic
